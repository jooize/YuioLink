# Per-project .envrc for direnv. Run `direnv allow` after this is created.
# Project-local TMPDIR so tools that respect it (nix-shell, build systems)
# write inside the per-project sandbox allow zone.
mkdir -p .tmp
export TMPDIR="$PWD/.tmp"

# If you use nix flakes / nix-direnv, uncomment:
# use flake
