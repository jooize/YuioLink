{% extends "minimal-layout.tmpl" %}

{% block style %}
.app-window { --window-width: 760px; }

#content {
    margin-top: 22px;
    font-size: 15px;
    line-height: 1.6;
    overflow-wrap: anywhere;
}

#content pre,
#content code {
    font-family: var(--font-mono);
    font-size: 13.5px;
}

#content pre {
    padding: 16px;
    border-radius: 12px;
    border: 0.5px solid var(--field-border);
    background: var(--field-bg);
    overflow-x: auto;
}

#content > code {
    display: block;
    white-space: pre-wrap;
    padding: 16px;
    border-radius: 12px;
    border: 0.5px solid var(--field-border);
    background: var(--field-bg);
}

#content h1, #content h2, #content h3 { letter-spacing: -0.02em; }
#content a { word-break: break-word; }
{% endblock %}

{% block head %}
    <link rel="stylesheet" href="/css/prism.css" data-noprefix />
{% endblock %}

{% block content %}
    {% if not encrypted %}
        {% if contentType == "markdown" %}
            <div id="content">
                {{ content|markdown }}
            </div>
        {% else %}
            <code id="content">
                {{ content|pygments:contentType }}
            </code>
        {% endif %}
    {% else %}
        {% if contentType == "markdown" %}
            <div id="content"></div>
        {% else %}
            <pre><code id="content" class="language-{{ contentType }}"></code></pre>
        {% endif %}
    {% endif %}
{% endblock %}

{% block script %}
    {% if encrypted %}
        <script src="/js/markdown.min.js"></script>
        <script src="/js/prism.js" data-default-language="markup"></script>
        <script>
            var key = window.location.hash;
        {% autoescape off %}
            var encryptedContent = '{{ content }}';
        {% endautoescape %}
            try {
                var decryptedContent = sjcl.decrypt(key.substr(1), encryptedContent);

                {% if contentType == "markdown" %}
                var html = markdown.toHTML(decryptedContent);
                {% else %}
                var html = decryptedContent;
                {% endif %}

                var contentElement = document.getElementById("content");
                contentElement.innerHTML = html;
            }
            catch (ex) {
                console.log("Could not decrypt paste content", ex);
            }
        </script>
    {% endif %}
{% endblock %}
